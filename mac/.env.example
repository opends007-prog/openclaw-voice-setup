# Whisper Server Configuration

# Path to the whisper.cpp ggml model file.
# install.sh will download ggml-medium.en.bin here by default.
WHISPER_MODEL_PATH=/usr/local/share/whisper.cpp/ggml-medium.en.bin

# Port the whisper-server listens on.
WHISPER_PORT=8080

# After installing Tailscale and authenticating, run `tailscale ip`
# on this Mac and note the IP here. The VM's voice-transcriber needs it.
# Example: TAILSCALE_MAC_IP=100.67.79.42
TAILSCALE_MAC_IP=YOUR_MAC_TAILSCALE_IP
