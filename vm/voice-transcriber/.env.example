# Discord Bot Token for the Voice Transcriber bot
# This is the SAME token you use for the OpenClaw Lucy agent.
# Both Lucy (text commands) and the voice transcriber (voice→text) connect
# to Discord as the same bot.
DISCORD_TOKEN=your_discord_bot_token_here

# Whisper Server URL
# Replace <MAC_TAILSCALE_IP> with your Mac's Tailscale IP address.
# Run `tailscale ip` on your Mac to find it.
WHISPER_API_URL=http://<MAC_TAILSCALE_IP>:8080/inference
